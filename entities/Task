{
  "name": "Task",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "description": "Task title"
    },
    "description": {
      "type": "string",
      "description": "Task description or brain dump content"
    },
    "status": {
      "type": "string",
      "enum": [
        "inbox",
        "today",
        "scheduled",
        "done"
      ],
      "default": "inbox",
      "description": "Task status"
    },
    "priority": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high",
        "critical"
      ],
      "default": "medium"
    },
    "xp_value": {
      "type": "number",
      "default": 25,
      "description": "XP reward for completing this task"
    },
    "due_date": {
      "type": "string",
      "format": "date"
    },
    "is_brain_dump": {
      "type": "boolean",
      "default": false,
      "description": "Whether this was a quick brain dump entry"
    }
  },
  "required": [
    "title"
  ]
}